{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits", "helpers:pinGitHubActionDigestsToSemver"],
  "timezone": "Europe/Berlin",
  "labels": ["dependencies"],
  "gitAuthor": "renovate[bot] <renovate[bot]@users.noreply.github.com>",
  "osvVulnerabilityAlerts": true,
  "dependencyDashboard": false,
  "prConcurrentLimit": 3,
  "schedule": ["before 6am on monday"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^autossh/build\\.yaml$/"
      ],
      "matchStrings": [
        "(?<depName>ghcr\\.io/home-assistant/[a-z0-9]+-base):(?<currentValue>[\\d.+-]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    { "matchManagers": ["github-actions"], "groupName": "github-actions", "automerge": true, "automergeType": "pr" }
  ]
}
